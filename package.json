{
  "name": "smartbi-toolkit",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite-plugin-smartbi": {
      "types": "./dist/vite-plugin-smartbi/index.d.ts",
      "import": "./dist/vite-plugin-smartbi.js",
      "require": "./dist/vite-plugin-smartbi.cjs"
    },
    "./vite-plugin-smartbix": {
      "types": "./dist/vite-plugin-smartbix/index.d.ts",
      "import": "./dist/vite-plugin-smartbix.js",
      "require": "./dist/vite-plugin-smartbix.cjs"
    },
    "./methods/*": {
      "types": "./dist/methods/*.d.ts",
      "import": "./dist/methods/*.js",
      "require": "./dist/methods/*.cjs"
    },
    "./*": {
      "types": "./dist/methods/*.d.ts",
      "import": "./dist/methods/*.js",
      "require": "./dist/methods/*.cjs"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lib-build": "vite build",
    "test:esm": "node test-imports.mjs",
    "test:cjs": "node test-cjs.cjs",
    "test:all": "npm run test:esm && npm run test:cjs",
    "test:build": "npm run build && npm run test:all"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.3",
    "path-browserify": "^1.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.1.0",
    "typescript": "~5.9.3",
    "vite": "7.3.1",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "keywords": [
    "typescript",
    "vite",
    "library"
  ],
  "author": "",
  "license": "MIT"
}
